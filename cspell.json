    "endef",
    "errorf",
    "gobin",
    "godoc",
    "gofumpt",
    "goimports",
    "golangci",
    "golines",
    "goroot",
    "gosec",
    "govulncheck",
    "govy",
    "govyconfig",
    "govytest",
    "keccak",
    "ldflags",
    "mypkg",
    "nobl",
    "pkgs",
    "println",
    "rtmp",
