{
  "allowCompoundWords": true,
  "language": "en_US",
  "dictionaries": [
    "companies",
    "misc",
    "softwareTerms",
    "go",
    "bash",
    "typescript",
    "node",
    "npm"
  ],
  "ignoreRegExpList": [
    "/\\|\\s+[T|G]{2,}\\s+\\|/g",
    "/\\b[13mn2][0-9A-HJ-NP-Za-km-z]{25,34}\\b/g",
    "/\\b(?:bc|tb)1[ac-hj-np-z02-9]{11,71}\\b/gi",
    "/123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz/g",
    "/qpzry9x8gf2tvdw0s3jn54khce6mua7l/g",
    "/https?:\\/\\/.*/g",
    "/github.*/g",
    "/nolint.*/g",
    "/nosec.*/g"
  ],
  "ignorePaths": [
    ".golangci.yml",
    "**/*.lock",
    "**/go*.mod",
    "**/go*.sum",
    "**/node_modules/**",
    "cspell.json",
    "CODEOWNERS",
    "bin/**",
    "docs/assets/**",
    "context7.json"
  ],
  "words": [
    "Bech",
    "Descriptionf",
    "Detailsf",
    "Elts",
    "Fset",
    "Keccak",
    "Messagef",
    "Skłodowska",
